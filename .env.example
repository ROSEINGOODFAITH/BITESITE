# --- Laurel Bath House Hydrogen storefront -------------------------------
# The site runs with NO env vars at all (mock mode: local catalog + session
# cart). Set the two PUBLIC_ vars below to switch to the live Storefront API.

# Session cookie secret — always set a real one in production.
SESSION_SECRET="generate-a-long-random-string"

# --- Live mode (Storefront API via the "LBH NEW TEST SITE" Headless channel)
# TBD-CONFIRM: actual myshopify domain for the store.
#PUBLIC_STORE_DOMAIN="laurelbathhouse.myshopify.com"
#PUBLIC_STOREFRONT_API_TOKEN="public-token-from-headless-channel"

# Optional: server-side private token (higher rate limits) + storefront id.
#PRIVATE_STOREFRONT_API_TOKEN=""
#PUBLIC_STOREFRONT_ID=""
